# ====== Scraper Service Configuration ======

# Wajib: API key untuk auth dari shared hosting -> service.
# Generate random panjang, mis: openssl rand -hex 32
SCRAPER_API_KEY=ganti-dengan-token-rahasia-anda

# Mode bypass Cloudflare:
#   "request" = pakai botasaurus_requests (ringan, cepat, cukup utk CF level standar)
#   "browser" = pakai Chrome headless via botasaurus.browser (lebih tahan CF JS-challenge)
SCRAPER_MODE=request

# Domain yang boleh di-scrape (comma-separated). Cegah open-proxy.
SCRAPER_WHITELIST=komiku.org,komiku.id,img.komiku.org,mangaku.top,img.mangaku.top,cover.mangaku.top

# Default User-Agent untuk fallback HTTP murni (botasaurus akan override sendiri)
SCRAPER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Timeout (detik) untuk setiap request browser/HTTP
SCRAPER_TIMEOUT=45

# Cache HTML per URL (detik). 0 = matikan.
SCRAPER_CACHE_TTL=3600

# Bind host & port (Railway override otomatis lewat $PORT)
HOST=0.0.0.0
PORT=8080

# CORS origins (comma-separated). "*" = semua. Untuk produksi taruh domain shared hosting.
CORS_ORIGINS=*
