# Salin file ini ke .env (untuk pengembangan lokal) atau set sebagai
# environment variable di hosting / Docker.
# .env tidak di-commit (lihat .gitignore) — hanya .env.example.

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bacakomik
DB_USER=bacakomik
DB_PASS=ganti-password-aman

# URL kanonik aplikasi (digunakan untuk sitemap & link absolut).
APP_URL=https://example.com

# Opsional: timezone PHP
TZ=Asia/Jakarta
